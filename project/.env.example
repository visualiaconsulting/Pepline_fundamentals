PROJECT_NAME=Fundamental Research Pipeline
LOG_LEVEL=INFO
REQUEST_TIMEOUT=20

# ------------------------------------------------------------
# UNIVERSO DE TICKERS (separados por coma, sin espacios)
# Añade o elimina tickers según tu portafolio
# ------------------------------------------------------------
# Universe to scan
UNIVERSE_TICKERS=NVDA,AMD,TSM,ASML,XOM,CVX,NEE,LMT,NOC,RIO,FCX,ALB,CAT,ROK,ETN,SMCI,PLTR,CRDO

# Sector keywords for strategic filters
TARGET_SECTORS=technology,semiconductors,energy,oil & gas,renewable energy,defense,aerospace,metals & mining,industrials

# Small/Mid and growth thresholds
SMALL_MID_CAP_THRESHOLD=10000000000
HIGH_GROWTH_THRESHOLD=15

# Hybrid universe discovery
TICKER_DISCOVERY_ENABLED=false
DISCOVERY_SOURCE=finviz
DISCOVERY_MAX_NEW_TICKERS=10
DISCOVERY_MIN_MARKET_CAP=100000000
DISCOVERY_MAX_MARKET_CAP=10000000000
DISCOVERY_MIN_SALES_GROWTH=15
DISCOVERY_SECTORS=technology,semiconductors,energy,oil & gas,renewable energy,defense,aerospace,metals & mining,industrials
TICKER_BLOCKLIST=

# Optional providers
USE_ALPHA_VANTAGE=false
ALPHA_VANTAGE_API_KEY=

# Optional LLM reports
ENABLE_LLM_SUMMARY=false
LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma4:e2b
OLLAMA_TIMEOUT_SECONDS=120
OLLAMA_MAX_HEADLINES_PER_TICKER=8
OLLAMA_ENABLE_DASHBOARD_SUMMARY=true
